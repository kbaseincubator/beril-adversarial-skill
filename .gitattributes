# Line-ending hygiene — cross-platform friendly
# See LAYOUT.md §Cross-platform considerations.

* text=auto

# Shell scripts must be LF (POSIX)
*.sh   text eol=lf

# PowerShell scripts must be CRLF (Windows PS host)
*.ps1  text eol=crlf

# YAML and TOML are always LF
*.yaml text eol=lf
*.yml  text eol=lf
*.toml text eol=lf

# Python is always LF
*.py   text eol=lf

# Markdown is always LF
*.md   text eol=lf
